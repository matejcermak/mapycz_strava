{
  "manifest_version": 3,
  "name": "Heatmapy — Strava Heatmap for Mapy.com",
  "version": "1.3.0",
  "description": "Overlay your Strava global and personal heatmaps (MTB / Gravel / Road / Run) on Mapy.com, and send planned routes to Strava.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "unlimitedStorage", "cookies"],
  "host_permissions": ["*://*.strava.com/*"],
  "content_scripts": [
    {
      "matches": [
        "*://mapy.cz/*",
        "*://*.mapy.cz/*",
        "*://mapy.com/*",
        "*://*.mapy.com/*"
      ],
      "js": ["mapy-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://mapy.cz/*",
        "*://*.mapy.cz/*",
        "*://mapy.com/*",
        "*://*.mapy.com/*"
      ],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Heatmapy — Strava Heatmap for Mapy.com",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
